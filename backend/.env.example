# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DB_NAME=jobflow
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ML Service - Embedding
EMBEDDING_PROVIDER=english
EMBEDDING_DIM=384

# ML Service - Data
DATA_DIR=./data
SKILL_ALIAS_PATH=ml_service/data/skill-alias.json

# ML Service - Synthetic data generation
NUM_CVS=800
NUM_JOBS=1500
NUM_POSITIVE_PAIRS=2000
RANDOM_SEED=42

# ML Service - GNN architecture
GNN_HIDDEN_CHANNELS=128
GNN_NUM_LAYERS=2

# ML Service - Training
LEARNING_RATE=0.001
WEIGHT_DECAY=0.00001
NUM_EPOCHS=50
EARLY_STOPPING_PATIENCE=10

# ML Service - Hybrid scoring weights (alpha + beta + gamma = 1.0)
HYBRID_ALPHA=0.6
HYBRID_BETA=0.3
HYBRID_GAMMA=0.1

# ML Service - Eligibility threshold
ELIGIBILITY_THRESHOLD=0.65
